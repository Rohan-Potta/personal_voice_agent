# Copy this file to ".env" and paste in your keys. The .env file is gitignored.
# All three are free to start (free credit / free tier) — links below.

# Speech-to-Text — Deepgram (free signup credit)
# Get a key: https://console.deepgram.com  ->  API Keys
DEEPGRAM_API_KEY=

# LLM brain — Groq running Llama (free)
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=

# Text-to-Speech — Cartesia (free tier)
# Get a key: https://play.cartesia.ai  ->  API Keys
CARTESIA_API_KEY=
