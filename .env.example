# Copy this file to ".env", set your name, and paste in your keys.
# The .env file is gitignored. All three keys are free to start — links below.

# The person this agent answers screening calls for (your full name).
OWNER_NAME=Your Name

# Speech-to-Text — Deepgram (free signup credit)
# Get a key: https://console.deepgram.com  ->  API Keys
DEEPGRAM_API_KEY=

# LLM brain — Groq running Llama (free)
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=

# Text-to-Speech — Cartesia (free tier)
# Get a key: https://play.cartesia.ai  ->  API Keys
CARTESIA_API_KEY=

# --- Only needed for real phone calls (Phase: telephony) ---
# From https://console.twilio.com -> Account Info panel
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
